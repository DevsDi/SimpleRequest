{
  "manifest_version": 3,
  "name": "SimpleRequest",
  "version": "2.0.2",
  "description": "Lightweight HTTP request debugging tool - Postman-style browser extension",
  "author": "SimpleRequest",
  "homepage_url": "https://github.com/simple-request",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SimpleRequest"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  }
}